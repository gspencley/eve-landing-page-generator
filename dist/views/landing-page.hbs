<div class="container">
  <header>
    <span class="badge">Personalized for {{firmName}}</span>
    <h1>Eve for {{firmName}}</h1>
    <p class="hero-copy">{{heroCopy}}</p>

    <div class="attributes">
      {{#if firmAttributes.practiceArea}}
        <span class="attr">Practice: {{firmAttributes.practiceArea}}</span>
      {{/if}}
      {{#if firmAttributes.firmSize}}
        <span class="attr">Size: {{firmAttributes.firmSize}}</span>
      {{/if}}
      {{#if firmAttributes.caseManagementSystem}}
        <span class="attr">CMS: {{firmAttributes.caseManagementSystem}}</span>
      {{/if}}
      {{#if firmAttributes.leadStatus}}
        <span class="attr">Status: {{firmAttributes.leadStatus}}</span>
      {{/if}}
    </div>
  </header>

  <section>
    <h2>Recommended resources</h2>
    <div class="grid">
      {{#each assets}}
        <article class="card" data-asset-id="{{this.id}}">
          <h3>{{this.title}}</h3>
          <p>{{this.description}}</p>
          <a
            class="btn asset-link"
            href="{{this.url}}"
            data-asset-id="{{this.id}}"
            target="_blank"
            rel="noopener noreferrer"
          >{{this.ctaLabel}}</a>
        </article>
      {{/each}}
    </div>
  </section>

  <section class="cta-panel">
    <h2>See Eve on your workflows</h2>
    <p>Book a 20-minute walkthrough tailored to {{firmName}}'s intake and drafting process.</p>
    <button class="btn" id="primary-cta" type="button">Book a demo</button>
  </section>

  <footer>
    <p>Powered by Eve · Page ID {{pageId}}</p>
  </footer>
</div>

<script>
  (function () {
    var pageId = '{{pageId}}';
    var baseUrl = '{{publicBaseUrl}}';

    function track(eventType, assetId, metadata) {
      fetch(baseUrl + '/events', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          pageId: pageId,
          eventType: eventType,
          assetId: assetId || undefined,
          metadata: metadata || undefined
        })
      }).catch(function () {});
    }

    document.querySelectorAll('.asset-link').forEach(function (link) {
      link.addEventListener('click', function () {
        track('asset_click', link.getAttribute('data-asset-id'));
      });
    });

    var cta = document.getElementById('primary-cta');
    if (cta) {
      cta.addEventListener('click', function () {
        track('cta_click');
        window.location.href = 'https://example.eve.legal/demo';
      });
    }

    // page_view is recorded server-side; client hook reserved for SPA/navigation extensions
  })();
</script>
